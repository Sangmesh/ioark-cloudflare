# Build-time (baked into the SPA by Vite). Set this in the Cloudflare Pages
# project: Settings -> Environment variables -> Build. Must equal the backend's
# BASE_DOMAIN and be the domain your tenant subdomains live under.
VITE_BASE_DOMAIN=iam.example.com

# NOTE: BACKEND_ORIGIN is NOT a build var. It is a *runtime* Pages Function
# environment variable (Settings -> Environment variables) consumed by
# functions/_middleware.js. Example:
#   BACKEND_ORIGIN=https://api.example.com
